@{
    Layout = null;
    var historyList = ViewBag.History as IEnumerable<dynamic>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>T-Shortener | High-Speed URL Shortener</title>

    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

    <div class="hero-section text-center shadow-sm">
        <div class="container">
            <h1 class="display-5 fw-bold mb-3"><i class="bi bi-link-45deg"></i> T-Shortener</h1>
            <p class="lead mb-4">High-performance URL shortener powered by Redis & Docker</p>

            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card glass-card p-4">
                        <form action="/Home/Shorten" method="post">
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white text-primary"><i class="bi bi-globe"></i></span>
                                <input type="url" name="originalUrl" class="form-control focus-ring" placeholder="Enter your long URL here..." required>
                                <button class="btn btn-primary px-4 fw-bold" type="submit">Shorten Now</button>
                            </div>
                        </form>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                    <div class="alert alert-danger mt-3 shadow-sm"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
                    }
                    @if (TempData["SuccessMsg"] != null)
                    {
                    <div class="alert alert-success mt-3 shadow-sm"><i class="bi bi-check2-circle"></i> @TempData["SuccessMsg"]</div>
                    }
                    @if (TempData["ShortUrl"] != null)
                    {
                    <div class="alert alert-success mt-3 shadow-sm text-start">
                        <h5 class="alert-heading"><i class="bi bi-check-circle-fill"></i> Success!</h5>
                        <p class="mb-1">Original URL: <a href="@TempData["OriginalUrl"]" target="_blank" class="text-muted">@TempData["OriginalUrl"]</a></p>
                        <hr>
                        <p class="mb-0 fs-5">Short URL: <a href="@TempData["ShortUrl"]" target="_blank" class="fw-bold text-success text-decoration-none">@TempData["ShortUrl"]</a></p>

                        <button class="btn btn-sm btn-outline-success mt-3" onclick="showQR('@TempData["OriginalUrl"]')">
                            <i class="bi bi-qr-code"></i> View Original QR
                        </button>
                    </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="container mb-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                <h4 class="fw-bold text-secondary mb-0"><i class="bi bi-clock-history"></i> Recent Shortened URLs</h4>

                <form action="/Home/DeleteAll" method="post" onsubmit="return confirm('WARNING: Are you sure you want to delete ALL history? This action cannot be undone!');">
                    <button type="submit" class="btn btn-sm btn-danger shadow-sm fw-bold">
                        <i class="bi bi-trash3-fill"></i> Clear All
                    </button>
                </form>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Short Code</th>
                                <th>Original URL</th>
                                <th>Created At</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (historyList != null)
                            {
                                foreach (var item in historyList)
                                {
                            <tr>
                                <td>
                                    <a href="/@item.ShortCode" target="_blank" class="fw-bold text-decoration-none">/@item.ShortCode</a>
                                </td>
                                <td>
                                    <span class="url-text text-muted" title="@item.OriginalUrl">@item.OriginalUrl</span>
                                </td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-dark" onclick="showQR('@item.OriginalUrl')" title="View QR Code">
                                        <i class="bi bi-qr-code"></i>
                                    </button>
                                </td>
                            </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center pb-4">
                    <h5 class="fw-bold mb-3">Original URL QR</h5>
                    <div id="qrcodeBox" class="d-flex justify-content-center"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>